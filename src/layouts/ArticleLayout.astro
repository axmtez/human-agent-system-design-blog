---
import SiteLayout from './SiteLayout.astro';
import { type ArticleEntry } from '../lib/articles.ts';

interface Props {
  title: string;
  date: Date;
  description?: string;
  readingTime: number;
  articles: ArticleEntry[];
}

const { title, date, description, readingTime, articles } = Astro.props;

const year = date.getFullYear();
const month = String(date.getMonth() + 1).padStart(2, '0');
const day = String(date.getDate()).padStart(2, '0');
const formattedDate = `${year}.${month}.${day}`;
---

<SiteLayout title={title} description={description} articles={articles}>
  <header class="tx-header">
    <div class="tx-header__status sys">TRANSMISSION // OPEN</div>
    <hr class="tx-rule" />
    <div class="tx-header__meta sys">
      {formattedDate} · 0847 HRS · EST. {readingTime} MIN
    </div>
    <hr class="tx-rule" />
    <h1 class="tx-header__title">{title}</h1>
    {description && (
      <p class="tx-header__lede">{description}</p>
    )}
  </header>
  <div class="article__body">
    <slot />
  </div>
  <footer class="tx-footer">
    <hr class="tx-rule" />
    <a href="/" class="tx-footer__end sys">◀ END TRANSMISSION · RETURN TO FREQ</a>
  </footer>
</SiteLayout>

<style>
  .tx-header {
    max-width: var(--measure-prose);
    margin-bottom: var(--space-8);
  }

  .tx-header__status {
    margin-bottom: var(--space-3);
  }

  .tx-header__meta {
    margin: var(--space-3) 0;
    font-variant-numeric: tabular-nums;
  }

  .tx-header__title {
    margin: var(--space-6) 0 0;
    font-family: var(--font-display);
    font-size: var(--text-3xl);
    font-weight: 900;
    line-height: var(--leading-tight);
    letter-spacing: -0.03em;
    color: var(--color-text-primary);
  }

  .tx-header__lede {
    max-width: var(--measure-prose);
    margin: var(--space-4) 0 0;
    color: var(--color-text-secondary);
    font-size: var(--text-lg);
    line-height: var(--leading-loose);
  }

  .article__body {
    max-width: var(--measure-prose);
  }

  .tx-footer {
    max-width: var(--measure-prose);
    margin-top: var(--space-16);
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .tx-footer__end {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-text-muted);
    text-decoration: none;
  }

  .tx-footer__end:hover {
    color: var(--color-accent);
  }
</style>
