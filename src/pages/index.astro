---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getSortedPosts, getPaginationForPosts } from '../lib/blog';

const allPosts = await getSortedPosts();
const { getPagePosts, totalPages } = getPaginationForPosts(allPosts);
const posts = getPagePosts(1);
---

<BaseLayout title="Blog" description="Human–agent system design blog.">
  <h1>Blog</h1>
  <ul>
    {posts.map((post) => (
      <li>
        <a href={`/${post.slug}`}>{post.data.title}</a>
        <time datetime={post.data.publishDate.toISOString()}>
          {post.data.publishDate.toLocaleDateString('en-CA', { year: 'numeric', month: 'long', day: 'numeric' })}
        </time>
      </li>
    ))}
  </ul>
  {totalPages > 1 && (
    <p>
      <a href="/page/2">Next page</a> · Page 1 of {totalPages}
    </p>
  )}
</BaseLayout>
