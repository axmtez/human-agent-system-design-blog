---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());
---

<BaseLayout title="Blog" description="Human-agent system design blog.">
  <article>
    <h1 class="text-4xl font-bold text-text mb-8">Blog</h1>
    <ol class="list-none p-0 m-0 flex flex-col gap-4">
      {posts.map((post) => (
        <li class="border-b border-border pb-4 last:border-0 last:pb-0">
          <a href={`/${post.slug}`} class="block group no-underline">
            <time datetime={post.data.publishDate.toISOString()} class="text-sm text-text-muted block mb-1">
              {post.data.publishDate.toLocaleDateString('en-CA', {
                year: 'numeric',
                month: 'short',
                day: 'numeric',
              })}
            </time>
            <span class="text-lg font-medium text-text group-hover:text-accent">{post.data.title}</span>
          </a>
        </li>
      ))}
    </ol>
  </article>
</BaseLayout>
