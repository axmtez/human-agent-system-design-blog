---
import SiteLayout from '../layouts/SiteLayout.astro';
import { articleSlug, getSortedArticles } from '../lib/articles.ts';

const articles = await getSortedArticles();
const title = 'HAS Design — Articles';
---

<SiteLayout title={title} description="Human–agent system design writing." articles={articles}>
  <header class="index-hero">
    <p class="index-hero__label">HAS Design</p>
    <p class="index-hero__tagline">Human · Agent · System</p>
    <hr class="index-hero__rule" />
  </header>
  <ul class="index-list">
    {
      articles.map((a) => (
        <li>
          <a href={`/${articleSlug(a.id)}`}>
            <span class="index-list__title">{a.data.title}</span>
            <time class="index-list__date" datetime={a.data.date.toISOString()}>
              {a.data.date.toLocaleDateString('en-CA', {
                year: 'numeric',
                month: 'short',
                day: 'numeric',
              })}
            </time>
          </a>
        </li>
      ))
    }
  </ul>
</SiteLayout>
