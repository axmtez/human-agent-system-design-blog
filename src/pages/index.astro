---
import BlogLayout from '../layouts/BlogLayout.astro';
---

<BlogLayout title="HAS Design" description="Human–agent system design." showFooter={false}>
  <div id="landing-page" class="diorama-view">
    <div id="diorama-mount" class="diorama-mount">
      <p class="diorama-mount__placeholder">DIORAMA LOADING</p>
    </div>
  </div>
</BlogLayout>

<style>
  .diorama-view {
    width: 100%;
    height: 100%;
    min-height: 0;
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }

  .diorama-mount {
    flex: 1;
    min-height: 0;
    width: 100%;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .diorama-mount__placeholder {
    font-family: var(--font-system);
    font-size: var(--text-sm);
    color: var(--color-text-dim);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin: 0;
  }
</style>
