---
import BlogLayout from '../layouts/BlogLayout.astro';

/** Beat label copy — final text for all 6 beats (ILI-444). */
const BEAT_LABELS = [
  { title: 'THE AIRSPACE', body: 'The full system in view.' },
  { title: 'THE CONTROLLER', body: 'One controller orchestrates the flows.' },
  { title: 'THE AIRCRAFT', body: 'Agents and users in the same airspace.' },
  { title: 'THE HANDOFF', body: 'Clear handoff from system to human.' },
  { title: 'THE GUARDRAILS', body: 'Guardrails keep everyone safe and aligned.' },
  { title: 'THIS IS HAS DESIGN', body: 'This is human–agent system design.' },
];
---

<BlogLayout title="HAS Design" description="Human–agent system design." showFooter={false}>
  <div id="landing-page" class="diorama-view">
    <div id="diorama-mount" class="diorama-mount">
      <div id="diorama-scroll-panel" class="diorama-scroll-panel">
        <div id="diorama-sticky-wrap" class="diorama-sticky-wrap">
          <div id="diorama-container" class="diorama-container"></div>
          <div id="diorama-labels" class="diorama-labels" aria-live="polite">
            {BEAT_LABELS.map((label, i) => (
              <div class="beat-label" data-beat={i} aria-hidden="true">
                <p class="beat-label__title">{label.title}</p>
                <p class="beat-label__body">{label.body}</p>
              </div>
            ))}
          </div>
        </div>
        <div id="diorama-scroll-track" class="diorama-scroll-track"></div>
      </div>
    </div>
  </div>
  <script>
    import '../scripts/landing-diorama';
  </script>
</BlogLayout>

<style>
  .diorama-view {
    width: 100%;
    height: 100vh;
    min-height: 0;
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }

  .diorama-mount {
    flex: 1;
    min-height: 0;
    width: 100%;
    overflow: hidden;
  }

  .diorama-scroll-panel {
    height: 100%;
    overflow: hidden;
    overflow-x: hidden;
  }

  .diorama-sticky-wrap {
    position: relative;
    height: 100%;
    width: 100%;
    background: var(--color-bg, #0a0a0a);
  }

  .diorama-container {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .diorama-labels {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 10;
    display: flex;
    align-items: flex-end;
    justify-content: flex-start;
    padding: 1.5rem 2rem;
  }

  .beat-label {
    position: absolute;
    transition: opacity 0.2s ease;
    opacity: 0;
    max-width: 20rem;
  }

  .beat-label__title {
    font-family: var(--font-system);
    font-size: 0.7rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-vector, #4a9eff);
    margin: 0 0 0.25rem 0;
  }

  .beat-label__body {
    font-family: var(--font-human);
    font-size: 0.95rem;
    color: var(--color-text-secondary, #bbb);
    margin: 0;
  }

  .diorama-scroll-track {
    height: 0;
    width: 100%;
  }

  .diorama-container.diorama-mobile-fallback {
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-bg);
  }

  .diorama-container.diorama-mobile-fallback::after {
    content: 'Human–agent system design';
    font-family: var(--font-system);
    font-size: var(--text-sm);
    letter-spacing: 0.08em;
    color: var(--color-text-dim);
  }
</style>
