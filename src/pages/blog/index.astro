---
import BlogLayout from '../../layouts/BlogLayout.astro';
import { getCollection } from 'astro:content';

const allPosts = (await getCollection('blog')).filter((p) => !p.data.draft);
const foundations = [...allPosts]
  .filter((p) => p.data.series === 'foundations')
  .sort((a, b) => (a.data.seriesPart ?? 0) - (b.data.seriesPart ?? 0));

const totalMinutes = foundations.reduce((sum, p) => sum + p.data.readingTime, 0);
const firstSlug = foundations[0]?.slug ?? '';
const partCount = foundations.length;

const foundationsData = foundations.map((p) => ({
  slug: p.slug,
  title: p.data.title,
  description: p.data.description,
  part: p.data.seriesPart ?? 0,
}));
---

<BlogLayout title="HAS Design — Briefing" description="Human–agent system design. A design discipline for systems where humans, autonomous agents, and infrastructure meet.">
  <script id="foundations-data" type="application/json" set:html={JSON.stringify(foundationsData)}></script>

  <!-- New reader briefing -->
  <div id="briefing-new" class="briefing" style="display: none;">
    <p class="briefing__label">BRIEFING</p>
    <hr class="rule" />

    <p class="briefing__declaration">
      HAS Design is a design discipline for the systems where humans, autonomous agents, and infrastructure meet.
    </p>

    <p class="briefing__problem">
      Agents are shipping into production. Teams are building AI-powered tools, copilots, and autonomous workflows without a shared language for how humans and agents should collaborate. The failure modes are already appearing — agents acting without authorization, humans losing situational awareness, systems with no designed recovery path.
    </p>
    <p class="briefing__problem">
      This publication builds the framework from first principles.
    </p>

    <p class="briefing__series-label">
      FOUNDATIONS · {partCount} PARTS · {totalMinutes} MIN TOTAL
    </p>
    <div class="briefing__series-list">
      {foundations.map((p, i) => (
        <div class="briefing__series-item">
          <span class="briefing__series-num">{String(i + 1).padStart(2, '0')}</span>
          <span class="briefing__series-title">{p.data.title}</span>
        </div>
      ))}
    </div>

    <a href={`/blog/${firstSlug}`} class="briefing__cta">BEGIN PART 1 →</a>

    <hr class="rule" />
    <p class="briefing__byline">By Chad Bercea</p>
    <p class="briefing__credit">Lead Product Designer, AI Developer Tools · Atlassian</p>
  </div>

  <!-- Returning reader briefing (in progress) -->
  <div id="briefing-returning" class="briefing" style="display: none;">
    <p class="briefing__label">WELCOME BACK</p>
    <hr class="rule" />

    <p class="briefing__progress">Foundations: <span id="read-count">0</span> of {partCount} complete.</p>

    <div id="briefing-returning-next" class="briefing__next-block">
      <p class="briefing__cleared">CLEARED FOR</p>
      <a id="next-article-link" href="#" class="briefing__next-title"></a>
      <p id="next-article-description" class="briefing__next-desc"></p>
      <a id="next-article-cta" href="#" class="briefing__cta">CONTINUE →</a>
    </div>

    <hr class="rule" />
    <div id="briefing-checklist" class="briefing__checklist">
      <!-- Filled by script -->
    </div>
  </div>

  <!-- Returning reader — series complete -->
  <div id="briefing-complete" class="briefing" style="display: none;">
    <p class="briefing__label briefing__label--complete">SERIES COMPLETE</p>
    <hr class="rule" />

    <p class="briefing__complete-message">You've completed all {partCount} parts of Foundations.</p>

    <div id="briefing-complete-list" class="briefing__checklist">
      <!-- Filled by script -->
    </div>

    <p class="briefing__explore">Explore more in the sidebar.</p>
  </div>

  <script is:inline>
    const STORAGE_KEY = 'has-design-read-articles';

    function getFoundationsData() {
      const el = document.getElementById('foundations-data');
      return el ? JSON.parse(el.textContent) : [];
    }

    function runBriefingState() {
      const path = window.location.pathname;
      if (path !== '/blog' && path !== '/blog/') return;

      const foundationsData = getFoundationsData();
      const partCount = foundationsData.length;
      const read = JSON.parse(localStorage.getItem(STORAGE_KEY) || '[]');
      const readCount = foundationsData.filter((a) => read.includes(a.slug)).length;
      const nextUnread = foundationsData.find((a) => !read.includes(a.slug));
      const allComplete = readCount === foundationsData.length;

      const elNew = document.getElementById('briefing-new');
      const elReturning = document.getElementById('briefing-returning');
      const elComplete = document.getElementById('briefing-complete');

      elNew.style.display = 'none';
      elReturning.style.display = 'none';
      elComplete.style.display = 'none';

      if (read.length === 0) {
        elNew.style.display = 'block';
        return;
      }

      if (allComplete) {
        elComplete.style.display = 'block';
        const listEl = document.getElementById('briefing-complete-list');
        if (listEl) {
          listEl.innerHTML = foundationsData
            .map(
              (a) =>
                `<div class="briefing__checklist-item"><span class="briefing__series-num">${String(a.part).padStart(2, '0')}</span><span class="briefing__check">✓</span><span class="briefing__checklist-title">${a.title}</span></div>`
            )
            .join('');
        }
        return;
      }

      elReturning.style.display = 'block';
      document.getElementById('read-count').textContent = readCount;

      const nextBlock = document.getElementById('briefing-returning-next');
      const nextLink = document.getElementById('next-article-link');
      const nextTitle = document.getElementById('next-article-title');
      const nextDesc = document.getElementById('next-article-description');
      const nextCta = document.getElementById('next-article-cta');

      if (nextUnread && nextBlock && nextLink && nextTitle && nextDesc && nextCta) {
        nextBlock.style.display = 'block';
        nextLink.href = '/blog/' + nextUnread.slug;
        nextTitle.textContent = nextUnread.title;
        nextDesc.textContent = nextUnread.description;
        nextCta.href = '/blog/' + nextUnread.slug;
        nextCta.style.display = 'inline-block';
      } else {
        nextBlock.style.display = 'none';
      }

      const checklist = document.getElementById('briefing-checklist');
      if (checklist) {
        const nextSlug = nextUnread ? nextUnread.slug : null;
        checklist.innerHTML = foundationsData
          .map((a) => {
            const isRead = read.includes(a.slug);
            const isNext = a.slug === nextSlug;
            const check = isRead ? '<span class="briefing__check">✓</span>' : '';
            const titleClass = isNext ? 'briefing__checklist-title briefing__checklist-title--next' : isRead ? 'briefing__checklist-title briefing__checklist-title--read' : 'briefing__checklist-title';
            const title = isRead || isNext ? `<a href="/blog/${a.slug}" class="${titleClass}">${a.title}</a>` : `<a href="/blog/${a.slug}" class="${titleClass}">${a.title}</a>`;
            return `<div class="briefing__checklist-item"><span class="briefing__series-num">${String(a.part).padStart(2, '0')}</span>${check}${title}</div>`;
          })
          .join('');
      }
    }

    runBriefingState();

    document.addEventListener('astro:after-swap', runBriefingState);
  </script>
</BlogLayout>

<style>
  .briefing {
    max-width: 36rem;
  }

  .briefing .rule {
    transform: scaleX(1);
  }

  .briefing__label {
    font-family: var(--font-system);
    font-size: var(--text-xs);
    color: var(--color-vector);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    margin: 0 0 var(--space-md);
  }

  .briefing__label--complete {
    color: #4ade80;
  }

  .briefing__declaration {
    font-family: var(--font-editorial);
    font-weight: 700;
    font-size: 2.5rem;
    line-height: 1.2;
    color: var(--color-text);
    margin: 0 0 var(--space-lg);
  }

  .briefing__problem {
    font-family: var(--font-human);
    font-weight: 400;
    font-size: var(--text-base);
    line-height: 1.7;
    color: var(--color-text-secondary);
    margin: 0 0 var(--space-md);
  }

  .briefing__problem:last-of-type {
    margin-bottom: var(--space-xl);
  }

  .briefing__series-label {
    font-family: var(--font-system);
    font-size: var(--text-xs);
    color: var(--color-text-dim);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin: 0 0 var(--space-sm);
  }

  .briefing__series-list {
    margin-bottom: var(--space-lg);
  }

  .briefing__series-item {
    display: flex;
    align-items: baseline;
    gap: var(--space-sm);
    margin-bottom: var(--space-xs);
  }

  .briefing__series-num {
    font-family: var(--font-system);
    font-size: var(--text-sm);
    font-weight: 700;
    color: var(--color-text-dim);
    min-width: 2rem;
  }

  .briefing__series-title {
    font-family: var(--font-human);
    font-weight: 500;
    font-size: var(--text-base);
    color: var(--color-text-muted);
  }

  .briefing__cta {
    font-family: var(--font-system);
    font-weight: 500;
    font-size: var(--text-sm);
    color: var(--color-vector);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    text-decoration: none;
    display: inline-block;
    margin-bottom: var(--space-xl);
    transition: color 150ms ease-out;
  }

  .briefing__cta:hover {
    color: var(--color-vector-bright);
  }

  .briefing__byline {
    font-family: var(--font-editorial);
    font-weight: 400;
    font-style: italic;
    font-size: var(--text-base);
    color: var(--color-text-muted);
    margin: 0 0 var(--space-xs);
  }

  .briefing__credit {
    font-family: var(--font-system);
    font-size: var(--text-xs);
    color: var(--color-text-dim);
    letter-spacing: 0.06em;
    margin: 0;
  }

  .briefing__progress {
    font-family: var(--font-human);
    font-size: var(--text-xl);
    color: var(--color-text-muted);
    margin: 0 0 var(--space-lg);
  }

  .briefing__cleared {
    font-family: var(--font-system);
    font-size: var(--text-xs);
    color: var(--color-vector);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    margin: 0 0 var(--space-xs);
  }

  .briefing__next-title {
    font-family: var(--font-editorial);
    font-weight: 700;
    font-size: 2rem;
    color: var(--color-text);
    display: block;
    margin: 0 0 var(--space-xs);
    text-decoration: none;
    transition: color 200ms ease-out;
  }

  .briefing__next-title:hover {
    color: var(--color-hover-warm);
  }

  .briefing__next-desc {
    font-family: var(--font-human);
    font-size: var(--text-base);
    color: var(--color-text-muted);
    margin: 0 0 var(--space-md);
  }

  .briefing__checklist {
    margin-top: var(--space-lg);
  }

  .briefing__checklist-item {
    display: flex;
    align-items: center;
    gap: var(--space-xs);
    margin-bottom: var(--space-xs);
  }

  .briefing__checklist-item .briefing__series-num {
    min-width: 2rem;
  }

  .briefing__check {
    color: #4ade80;
    font-weight: 700;
    font-size: var(--text-sm);
    min-width: 1rem;
  }

  .briefing__checklist-title {
    font-family: var(--font-human);
    font-weight: 400;
    font-size: var(--text-base);
    color: var(--color-text-dim);
    text-decoration: none;
  }

  .briefing__checklist-title:hover {
    color: var(--color-text-muted);
  }

  .briefing__checklist-title--next {
    font-weight: 600;
    color: var(--color-text);
  }

  .briefing__checklist-title--read {
    color: var(--color-text-dim);
  }

  .briefing__complete-message {
    font-family: var(--font-human);
    font-size: var(--text-base);
    color: var(--color-text-muted);
    margin: 0 0 var(--space-lg);
  }

  .briefing__explore {
    font-family: var(--font-system);
    font-size: var(--text-sm);
    color: var(--color-text-dim);
    margin: var(--space-lg) 0 0;
  }
</style>
