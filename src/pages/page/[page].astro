---
import BlogLayout from '../../layouts/BlogLayout.astro';
import { getSortedPosts, getPaginationForPosts } from '../../lib/blog';
import type { GetStaticPaths } from 'astro';

export const getStaticPaths: GetStaticPaths = async () => {
  const allPosts = await getSortedPosts();
  const { totalPages, getPagePosts } = getPaginationForPosts(allPosts);
  return Array.from({ length: Math.max(0, totalPages - 1) }, (_, i) => {
    const pageNum = i + 2;
    return {
      params: { page: String(pageNum) },
      props: {
        currentPage: pageNum,
        totalPages,
        posts: getPagePosts(pageNum),
      },
    };
  });
};

const { currentPage, totalPages, posts } = Astro.props;
---

<BlogLayout title={`Blog — Page ${currentPage}`} description="Human–agent system design blog.">
  <h1>Blog</h1>
  <ul>
    {posts.map((post) => (
      <li>
        <a href={`/${post.slug}`}>{post.data.title}</a>
        <time datetime={post.data.publishDate.toISOString()}>
          {post.data.publishDate.toLocaleDateString('en-CA', { year: 'numeric', month: 'long', day: 'numeric' })}
        </time>
      </li>
    ))}
  </ul>
  <nav>
    {currentPage > 1 && (
      <a href={currentPage === 2 ? '/' : `/page/${currentPage - 1}`}>Previous</a>
    )}
    <span> Page {currentPage} of {totalPages} </span>
    {currentPage < totalPages && (
      <a href={`/page/${currentPage + 1}`}>Next</a>
    )}
  </nav>
</BlogLayout>
