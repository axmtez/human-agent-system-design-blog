---
import BlogLayout from '../../layouts/BlogLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const sequences: Record<string, { title: string; description: string; meta: string; postSlugs: string[] }> = {
    'start-here': {
      title: 'Introduction to HAS Design',
      description: 'A short path through core concepts.',
      meta: '3 articles',
      postSlugs: ['sample-post', 'defining-handoff-protocols', 'human-in-the-loop-patterns'],
    },
    'deep-dive': {
      title: 'Guardrails & Feedback Loops',
      description: 'A 3-part series on designing safe boundaries.',
      meta: '3 articles',
      postSlugs: ['feedback-loops-guardrails', 'implementing-approval-workflows', 'metrics-observability'],
    },
    'the-stack': {
      title: 'System Design from Bottom Up',
      description: 'The technical stack of HAS.',
      meta: '4 articles',
      postSlugs: ['structured-outputs-and-schemas', 'context-windows-and-memory', 'scaling-agent-workflows', 'beyond-the-demo'],
    },
  };
  return Object.keys(sequences).map((slug) => ({
    params: { slug },
    props: { slug, ...sequences[slug] },
  }));
}

const { title, description, meta, postSlugs } = Astro.props;
const posts = await getCollection('blog');
const ordered = postSlugs.map((s) => posts.find((p) => p.slug === s)).filter(Boolean);
---

<BlogLayout title={title} description={description}>
  <article>
    <header>
      <h1>{title}</h1>
      <p>{description}</p>
      <p>{meta}</p>
    </header>
    <ol>
      {ordered.map((post, i) => (
        <li>
          <a href={`/${post.slug}`}>{post.data.title}</a>
        </li>
      ))}
    </ol>
    <p><a href="/">Back to home</a></p>
  </article>
</BlogLayout>
