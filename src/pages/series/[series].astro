---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import type { GetStaticPaths } from 'astro';
import type { CollectionEntry } from 'astro:content';

type Post = CollectionEntry<'blog'>;

export const getStaticPaths: GetStaticPaths = async () => {
  const seriesTitles: Record<string, string> = {
    foundations: 'Foundations',
    guardrails: 'Guardrails',
    'the-stack': 'The Stack',
  };
  const seriesDescriptions: Record<string, string> = {
    foundations:
      'Core concepts for human-agent system design: boundaries, handoffs, and human-in-the-loop patterns.',
    guardrails:
      'Feedback loops, approval workflows, and observability so human-agent systems stay safe and aligned.',
    'the-stack':
      'From structured outputs and context to scaling and production: the technical stack of HAS.',
  };

  const posts = await getCollection('blog', ({ data }) => !data.draft);
  const bySeries = new Map<string, Post[]>();

  for (const p of posts) {
    const s = p.data.series;
    if (s) {
      const list = bySeries.get(s) ?? [];
      list.push(p);
      bySeries.set(s, list);
    }
  }

  return Array.from(bySeries.entries()).map(([series, seriesPosts]) => {
    const sorted = [...seriesPosts].sort(
      (a, b) => (a.data.seriesPart ?? 0) - (b.data.seriesPart ?? 0)
    );
    const partCount = sorted.length;
    const totalMinutes = sorted.reduce((sum, p) => sum + p.data.readingTime, 0);
    const firstPost = sorted[0] ?? null;
    const title = seriesTitles[series] ?? series.replace(/-/g, ' ').replace(/\b\w/g, (c) => c.toUpperCase());
    const description = seriesDescriptions[series] ?? `Articles in the ${title} series.`;

    return {
      params: { series },
      props: {
        series,
        title,
        description,
        partCount,
        totalMinutes,
        articles: sorted,
        firstPost,
      },
    };
  });
};

const { series, title, description, partCount, totalMinutes, articles, firstPost } = Astro.props;

function partNum(n: number) {
  return String(n).padStart(2, '0');
}
---

<BaseLayout title={title} description={description}>
  <article class="sector">
    <header class="sector__header">
      <p class="sector__label">SECTOR</p>
      <h1 class="sector__title">{title}</h1>
      <p class="sector__desc">{description}</p>
      <p class="sector__stats">
        {partCount} PARTS · {totalMinutes} MIN TOTAL
      </p>
    </header>
    <hr class="rule" />

    <ol class="sector__list">
      {articles.map((post, i) => (
        <>
          {i > 0 && <hr class="rule" />}
          <li class="sector__item">
            <div class="sector__part-num">{partNum(post.data.seriesPart ?? i + 1)}</div>
            <a href={`/${post.slug}`} class="sector__entry content-link">
              <h2 class="sector__entry-title">{post.data.title}</h2>
              <p class="sector__entry-desc">{post.data.description}</p>
              <p class="sector__entry-meta">{post.data.readingTime} MIN READ</p>
              <span class="sector__entry-read">READ →</span>
            </a>
          </li>
        </>
      ))}
    </ol>

    {firstPost && (
      <>
        <hr class="rule" />
        <p class="sector__cta">
          <a href={`/${firstPost.slug}`} class="vector">BEGIN WITH PART 1 →</a>
        </p>
        <hr class="rule" />
      </>
    )}
  </article>
</BaseLayout>

<style>
  .sector {
    max-width: 42rem;
    margin: 0 auto;
    padding: var(--space-lg) var(--space-md);
  }

  .sector__header {
    margin-bottom: var(--space-md);
  }

  .sector__label {
    font-family: var(--font-system);
    font-size: var(--text-xs);
    color: var(--color-vector);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    margin: 0 0 var(--space-xs);
  }

  .sector__title {
    font-family: var(--font-editorial);
    font-size: var(--text-3xl);
    font-weight: 700;
    color: var(--color-text);
    margin: 0 0 var(--space-sm);
  }

  .sector__desc {
    font-family: var(--font-human);
    font-size: var(--text-base);
    color: var(--color-text-secondary);
    margin: 0 0 var(--space-sm);
  }

  .sector__stats {
    font-family: var(--font-system);
    font-size: var(--text-sm);
    color: var(--color-text-dim);
    margin: 0;
  }

  .sector__list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .sector__item {
    display: grid;
    grid-template-columns: 60px 1fr;
    gap: 0 var(--space-md);
    align-items: start;
    padding: var(--space-md) 0;
  }

  .sector__part-num {
    font-family: var(--font-system);
    font-size: var(--text-2xl);
    font-weight: 700;
    color: var(--color-text-dim);
  }

  .sector__entry {
    display: block;
    text-decoration: none;
    color: inherit;
    cursor: pointer;
    position: relative;
  }

  .sector__entry:visited {
    color: inherit;
  }

  .sector__entry-title {
    font-family: var(--font-human);
    font-weight: 600;
    font-size: var(--text-xl);
    color: var(--color-text);
    margin: 0 0 var(--space-xs);
    transition: color 200ms ease-out;
  }

  .sector__entry:hover .sector__entry-title {
    color: var(--color-hover-warm);
  }

  .sector__entry-desc {
    font-family: var(--font-human);
    font-size: var(--text-lg);
    color: var(--color-text-muted);
    margin: 0 0 var(--space-xs);
  }

  .sector__entry-meta {
    font-family: var(--font-system);
    font-size: var(--text-xs);
    color: var(--color-text-dim);
    margin: 0;
  }

  .sector__entry-read {
    font-family: var(--font-system);
    font-size: var(--text-xs);
    color: var(--color-vector);
    position: absolute;
    right: 0;
    top: 0;
    opacity: 0;
    transform: translateX(8px);
    transition: opacity 150ms ease-out, transform 150ms ease-out;
  }

  .sector__entry:hover .sector__entry-read {
    opacity: 1;
    transform: translateX(0);
  }

  .sector__cta {
    margin: var(--space-md) 0;
  }
</style>
