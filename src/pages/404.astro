---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Page not found" description="The page you are looking for does not exist.">
  <article>
    <h1 class="text-4xl font-bold text-text mb-4">Page not found</h1>
    <p class="text-text-muted mb-6">The page you are looking for does not exist or has been moved.</p>
    <a href="/" class="text-accent underline underline-offset-2">Back to blog</a>
  </article>
</BaseLayout>
