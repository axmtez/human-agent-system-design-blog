---
import BlogLayout from '../layouts/BlogLayout.astro';
import { getCollection } from 'astro:content';
import type { GetStaticPaths } from 'astro';
import type { CollectionEntry } from 'astro:content';

type Post = CollectionEntry<'blog'>;

export const getStaticPaths: GetStaticPaths = async () => {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  const bySlug = new Map(posts.map((p) => [p.slug, p]));

  return posts.map((post) => {
    const prereqPosts = (post.data.prerequisites ?? [])
      .map((slug) => bySlug.get(slug))
      .filter((p) => p != null) as Post[];
    const nextPost = post.data.nextArticle
      ? (bySlug.get(post.data.nextArticle) ?? null)
      : null;
    const prevPost = post.data.prevArticle
      ? (bySlug.get(post.data.prevArticle) ?? null)
      : null;
    return {
      params: { slug: post.slug },
      props: { post, prereqPosts, nextPost, prevPost },
    };
  });
};

const { post, prereqPosts, nextPost, prevPost } = Astro.props;
const { Content } = await post.render();

function formatSquawkDate(d: Date) {
  return d.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }).toUpperCase();
}

function squawkSeriesPart(post: Post): string {
  const { series, seriesPart, seriesTotal, altitude } = post.data;
  if (series && seriesPart != null && seriesTotal != null) {
    const name = series.toUpperCase().replace(/-/g, ' ');
    return `${name} · PART ${seriesPart} OF ${seriesTotal}`;
  }
  return altitude.toUpperCase().replace(/-/g, ' ');
}

const hasHandoff = nextPost || prevPost;
const showUpdated =
  post.data.updatedDate &&
  post.data.updatedDate.valueOf() !== post.data.publishDate.valueOf();
---

<BlogLayout title={post.data.title} description={post.data.description}>
  <div class="reading-progress" aria-hidden="true"></div>
  <article>
    <!-- Squawk Bar -->
    <div class="article-squawk animate-in">
      <span>{squawkSeriesPart(post)}</span>
      <span> · </span>
      <span>{post.data.readingTime} MIN READ</span>
      <span> · </span>
      <span>{formatSquawkDate(post.data.publishDate)}</span>
      {showUpdated && (
        <>
          <span> · </span>
          <span>UPDATED {formatSquawkDate(post.data.updatedDate)}</span>
        </>
      )}
    </div>
    <hr class="rule" />

    <!-- Prerequisites -->
    {prereqPosts.length > 0 && (
      <div class="article-prereqs animate-in">
        <p class="article-prereqs__label">CLEARANCE REQUIRED</p>
        <ul class="article-prereqs__list">
          {prereqPosts.map((p) => (
            <li>
              <a href={`/${p.slug}`} class="article-prereqs__link">→ {p.data.title}</a>
            </li>
          ))}
        </ul>
        <p class="article-prereqs__note">
          These provide context for what follows. You can continue without them.
        </p>
        <hr class="rule" />
      </div>
    )}

    <!-- Article Header -->
    <header class="article-header animate-in">
      <h1 class="article-header__title">{post.data.title}</h1>
      <p class="article-header__deck">{post.data.description}</p>
      {post.data.author && (
        <p class="article-header__byline">By {post.data.author}</p>
      )}
    </header>
    <hr class="rule" />

    <!-- Article Body (tripled for scroll-to-end testing) -->
    <div class="article-body">
      <Content />
      <Content />
      <Content />
    </div>
    <div id="article-end-sentinel" data-slug={post.slug} aria-hidden="true"></div>

    <!-- Handoff Block -->
    {hasHandoff && (
      <>
        <hr class="rule article-handoff-rule" />
        <div class="article-handoff animate-in">
          {prevPost && (
            <div class="article-handoff__prev">
              <a href={`/${prevPost.slug}`} class="article-handoff__prev-label">← PREVIOUS</a>
              <a href={`/${prevPost.slug}`} class="article-handoff__prev-title">{prevPost.data.title}</a>
            </div>
          )}
          {nextPost && (
            <div class="article-handoff__next">
              <p class="article-handoff__label">CLEARED FOR</p>
              <a href={`/${nextPost.slug}`} class="article-handoff__title">{nextPost.data.title}</a>
              <p class="article-handoff__desc">{nextPost.data.description}</p>
              <a href={`/${nextPost.slug}`} class="article-handoff__cta">CONTINUE →</a>
            </div>
          )}
        </div>
      </>
    )}

    <!-- Tags -->
    {post.data.tags.length > 0 && (
      <>
        <p class="article-tags">
          {post.data.tags.map((tag, i) => (
            <>
              {i > 0 && <span> · </span>}
              <a href={`/tags/${tag}`} class="article-tags__link">{tag.toUpperCase().replace(/-/g, ' ')}</a>
            </>
          ))}
        </p>
        <hr class="rule" />
      </>
    )}
  </article>
</BlogLayout>

<style>
  /* Content panel constraints — left-aligned, max-widths */
  .article-squawk,
  .article-header,
  .article-handoff,
  .article-prereqs {
    max-width: 56rem;
  }

  .article-body {
    max-width: 42rem;
  }

  .article-tags {
    max-width: 56rem;
  }

  /* Squawk bar */
  .article-squawk {
    font-family: var(--font-system);
    font-size: var(--text-xs);
    color: var(--color-text-dim);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin: 0 0 var(--space-md);
  }

  /* Prerequisites */
  .article-prereqs__label {
    font-family: var(--font-system);
    font-size: var(--text-xs);
    color: var(--color-vector);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    margin: var(--space-md) 0 var(--space-xs);
  }

  .article-prereqs__list {
    list-style: none;
    padding: 0;
    margin: 0 0 var(--space-sm);
  }

  .article-prereqs__list li {
    margin-bottom: var(--space-xs);
  }

  .article-prereqs__link {
    font-family: var(--font-system);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    text-decoration: none;
  }

  .article-prereqs__link:hover {
    color: var(--color-text);
  }

  .article-prereqs__note {
    font-family: var(--font-human);
    font-size: var(--text-sm);
    font-style: italic;
    color: var(--color-text-dim);
    margin: 0 0 var(--space-md);
  }

  /* Article header */
  .article-header {
    margin: var(--space-md) 0;
  }

  .article-header__title {
    font-family: var(--font-editorial);
    font-size: var(--text-3xl);
    font-weight: 700;
    color: var(--color-text);
    margin: 0 0 var(--space-sm);
  }

  .article-header__deck {
    font-family: var(--font-editorial);
    font-weight: 400;
    font-style: italic;
    font-size: var(--text-xl);
    color: var(--color-text-muted);
    margin: 0 0 var(--space-xs);
  }

  .article-header__byline {
    font-family: var(--font-editorial);
    font-weight: 400;
    font-style: italic;
    font-size: var(--text-base);
    color: var(--color-text-dim);
    margin: 0;
  }

  /* Article body — prose */
  .article-body {
    font-family: var(--font-human);
    font-size: var(--text-base);
    line-height: 1.7;
    color: var(--color-text-secondary);
    margin: var(--space-md) 0;
  }

  .article-body :global(h2) {
    font-family: var(--font-human);
    font-weight: 600;
    font-size: var(--text-2xl);
    color: var(--color-text);
    margin-top: var(--space-xl);
    margin-bottom: var(--space-md);
    line-height: 1.3;
  }

  .article-body :global(h3) {
    font-family: var(--font-human);
    font-weight: 600;
    font-size: var(--text-xl);
    color: var(--color-text);
    margin-top: var(--space-lg);
    margin-bottom: var(--space-sm);
    line-height: 1.3;
  }

  .article-body :global(p) {
    margin-bottom: var(--space-md);
  }

  .article-body :global(a) {
    color: var(--color-vector);
    text-decoration: none;
  }

  .article-body :global(a:hover) {
    text-decoration: underline;
  }

  .article-body :global(blockquote) {
    font-family: var(--font-editorial);
    font-size: var(--text-xl);
    font-style: italic;
    color: var(--color-text-muted);
    border-left: 2px solid var(--color-vector);
    padding-left: var(--space-md);
    margin: var(--space-lg) 0;
  }

  .article-body :global(pre) {
    font-family: var(--font-system);
    font-size: var(--text-sm);
    background: #111;
    padding: var(--space-md);
    border-left: 2px solid var(--color-rule-active);
    overflow-x: auto;
    margin: var(--space-md) 0;
    line-height: 1.5;
  }

  .article-body :global(code) {
    font-family: var(--font-system);
    font-size: 0.9em;
    background: #111;
    padding: 2px 6px;
    border-radius: 2px;
  }

  .article-body :global(pre code) {
    background: none;
    padding: 0;
    border-radius: 0;
  }

  .article-body :global(ul),
  .article-body :global(ol) {
    margin-bottom: var(--space-md);
    padding-left: var(--space-lg);
    color: var(--color-text-secondary);
  }

  .article-body :global(li) {
    margin-bottom: var(--space-xs);
    line-height: 1.65;
  }

  .article-body :global(img) {
    max-width: 100%;
    height: auto;
    margin: var(--space-lg) 0;
    border: 1px solid var(--color-rule);
  }

  .article-body :global(hr) {
    border: none;
    border-top: 1px solid var(--color-rule);
    margin: var(--space-xl) 0;
  }

  /* Article end sentinel */
  #article-end-sentinel {
    height: 1px;
    width: 100%;
    margin: 0;
    padding: 0;
    border: none;
    pointer-events: none;
    visibility: hidden;
  }

  /* Handoff block */
  .article-handoff-rule {
    margin: var(--space-xl) 0;
  }

  .article-handoff {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-lg);
    align-items: start;
  }

  .article-handoff > *:only-child {
    grid-column: 1 / -1;
  }

  .article-handoff__label {
    font-family: var(--font-system);
    font-size: var(--text-xs);
    color: var(--color-vector);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    margin: 0 0 var(--space-xs);
  }

  .article-handoff__title {
    font-family: var(--font-human);
    font-weight: 600;
    font-size: var(--text-2xl);
    color: var(--color-text);
    display: block;
    margin: 0 0 var(--space-xs);
    text-decoration: none;
    transition: color 200ms ease-out;
  }

  .article-handoff__title:hover {
    color: var(--color-hover-warm);
  }

  .article-handoff__desc {
    font-family: var(--font-human);
    font-size: var(--text-lg);
    color: var(--color-text-muted);
    margin: 0 0 var(--space-sm);
  }

  .article-handoff__cta {
    font-family: var(--font-system);
    font-size: var(--text-sm);
    color: var(--color-vector);
    text-decoration: none;
  }

  .article-handoff__cta:hover {
    text-decoration: underline;
  }

  .article-handoff__prev-label {
    font-family: var(--font-system);
    font-size: var(--text-xs);
    color: var(--color-text-dim);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    display: block;
    margin: 0 0 var(--space-xs);
    text-decoration: none;
  }

  .article-handoff__prev-label:hover {
    color: var(--color-text-muted);
  }

  .article-handoff__prev-title {
    font-family: var(--font-system);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    display: block;
    margin: 0;
    text-decoration: none;
  }

  .article-handoff__prev-title:hover {
    color: var(--color-text);
  }

  /* Tags */
  .article-tags {
    font-family: var(--font-system);
    font-size: var(--text-xs);
    color: var(--color-text-dim);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin: var(--space-md) 0 0;
  }

  .article-tags__link {
    color: var(--color-text-dim);
    text-decoration: none;
  }

  .article-tags__link:hover {
    color: var(--color-text-muted);
  }

  @media (max-width: 640px) {
    .article-handoff {
      grid-template-columns: 1fr;
    }
  }

  .reading-progress {
    position: fixed;
    top: 0;
    left: 0;
    height: 2px;
    background-color: var(--color-vector);
    width: 0%;
    z-index: 9999;
    transition: width 100ms linear;
    pointer-events: none;
  }
</style>
<script>
  document.addEventListener('DOMContentLoaded', () => {
    const progressBar = document.querySelector('.reading-progress');
    const contentPanel = document.getElementById('content-panel');
    if (progressBar) {
      const updateProgress = () => {
        if (contentPanel) {
          const { scrollTop, scrollHeight, clientHeight } = contentPanel;
          const scrollHeightTotal = scrollHeight - clientHeight;
          const progress = scrollHeightTotal > 0 ? (scrollTop / scrollHeightTotal) * 100 : 0;
          (progressBar as HTMLElement).style.width = Math.min(progress, 100) + '%';
        } else {
          const scrollHeight = document.body.scrollHeight - window.innerHeight;
          const progress = scrollHeight > 0 ? (window.scrollY / scrollHeight) * 100 : 0;
          (progressBar as HTMLElement).style.width = Math.min(progress, 100) + '%';
        }
      };
      if (contentPanel) {
        contentPanel.addEventListener('scroll', updateProgress, { passive: true });
      } else {
        window.addEventListener('scroll', updateProgress, { passive: true });
      }
      updateProgress();
    }
  });
</script>
