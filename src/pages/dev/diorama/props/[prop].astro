---
if (!import.meta.env.DEV) {
  return Astro.redirect('/');
}

export function getStaticPaths() {
  const validProps = [
    'runway', 'tower', 'taxiways', 'aircraft', 'aircraft-parked',
    'aircraft-taxiing', 'aircraft-approach', 'aircraft-enroute',
  ];
  return validProps.map((prop) => ({ params: { prop } }));
}

const validProps = [
  'runway', 'tower', 'taxiways', 'aircraft', 'aircraft-parked',
  'aircraft-taxiing', 'aircraft-approach', 'aircraft-enroute',
];

const prop = Astro.params.prop ?? 'runway';
const propId = validProps.includes(prop) ? prop : 'runway';
const title = propId.split('-').map((w) => w.charAt(0).toUpperCase() + w.slice(1)).join(' ');
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Diorama · Prop: {title}</title>
    <style>
      * { box-sizing: border-box; }
      html, body { margin: 0; height: 100%; overflow: hidden; }
      #diorama-container {
        width: 100vw;
        height: 100vh;
        position: relative;
      }
      #diorama-scene-info {
        position: absolute;
        left: 0;
        bottom: 0;
        padding: 0.5rem 0.75rem;
        background: rgba(0,0,0,0.7);
        color: #aaa;
        font-family: ui-monospace, monospace;
        font-size: 12px;
        z-index: 5;
        pointer-events: none;
      }
      .prop-label {
        position: absolute;
        left: 0;
        top: 0;
        padding: 0.5rem 0.75rem;
        background: rgba(0,0,0,0.7);
        color: #4a9eff;
        font-family: ui-monospace, monospace;
        font-size: 14px;
        z-index: 5;
        pointer-events: none;
      }
    </style>
  </head>
  <body>
    <div id="diorama-container" data-prop={propId}></div>
    <div class="prop-label" aria-hidden="true">Prop: {title}</div>
    <div id="diorama-scene-info" aria-live="polite">—</div>
    <script src="../../../../scripts/dev-diorama-prop.ts" />
  </body>
</html>
