---
if (!import.meta.env.DEV) {
  return Astro.redirect('/');
}
const props = [
  { id: 'runway', label: 'Runway' },
  { id: 'tower', label: 'Tower' },
  { id: 'taxiways', label: 'Ramp' },
  { id: 'aircraft-parked', label: 'Aircraft — Parked' },
  { id: 'aircraft-taxiing', label: 'Aircraft — Taxiing' },
  { id: 'aircraft-approach', label: 'Aircraft — Approach' },
  { id: 'aircraft-enroute', label: 'Aircraft — En route' },
];
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Diorama · Props grid</title>
    <style>
      * { box-sizing: border-box; }
      html, body { margin: 0; height: 100%; background: #0a0a0a; }
      .props-page {
        display: flex;
        flex-direction: column;
        height: 100%;
        padding: 0;
      }
      .props-grid {
        flex: 1;
        min-height: 0;
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        grid-template-rows: repeat(3, 1fr);
        gap: 0;
      }
      .prop-cell {
        min-width: 0;
        min-height: 0;
        border: 1px solid #555;
        position: relative;
        overflow: hidden;
      }
      .prop-cell canvas {
        display: block;
        width: 100%;
        height: 100%;
      }
      .prop-cell__label {
        position: absolute;
        left: 0;
        right: 0;
        bottom: 0;
        padding: 0.25rem 0.35rem;
        background: rgba(0,0,0,0.8);
        color: #888;
        font-family: ui-monospace, monospace;
        font-size: 10px;
        pointer-events: none;
      }
      .props-nav {
        flex-shrink: 0;
        padding: 0.5rem 0.75rem;
        background: rgba(0,0,0,0.5);
        color: #888;
        font-family: ui-monospace, monospace;
        font-size: 12px;
      }
      .props-nav a { color: #6ab; text-decoration: none; }
      .props-nav a:hover { color: #4a9eff; }
    </style>
  </head>
  <body>
    <div class="props-page">
      <div class="props-grid" id="props-grid">
        {props.map(({ id, label }) => (
          <div class="prop-cell" data-prop={id}>
            <span class="prop-cell__label">{label}</span>
          </div>
        ))}
      </div>
      <nav class="props-nav" aria-label="Prop links">
        <a href="/dev/diorama/environment">← Diorama dev</a>
        {' · View single: '}
        {props.map(({ id, label }, i) => (
          <>
            {i ? ' · ' : null}
            <a href={`/dev/diorama/props/${id}`}>{label}</a>
          </>
        ))}
      </nav>
    </div>
    <script src="../../../../scripts/dev-diorama-props-grid.ts" />
  </body>
</html>
