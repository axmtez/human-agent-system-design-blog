---
if (!import.meta.env.DEV) {
  return Astro.redirect('/');
}
/** Beat label copy — final text for all 6 beats (ILI-444). */
const BEAT_LABELS = [
  { title: 'THE AIRSPACE', body: 'The full system in view.' },
  { title: 'THE CONTROLLER', body: 'One controller orchestrates the flows.' },
  { title: 'THE AIRCRAFT', body: 'Agents and users in the same airspace.' },
  { title: 'THE HANDOFF', body: 'Clear handoff from system to human.' },
  { title: 'THE GUARDRAILS', body: 'Guardrails keep everyone safe and aligned.' },
  { title: 'THIS IS HAS DESIGN', body: 'This is human–agent system design.' },
];
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Diorama · Scroll</title>
    <style>
      * { box-sizing: border-box; }
      html, body { margin: 0; height: 100%; }
      #diorama-scroll-panel {
        height: 100vh;
        overflow-y: auto;
        overflow-x: hidden;
      }
      #diorama-sticky-wrap {
        position: sticky;
        top: 0;
        height: 80vh;
        width: 100%;
        background: #0a0a0a;
      }
      #diorama-container {
        width: 100%;
        height: 100%;
        position: relative;
      }
      #diorama-labels {
        position: absolute;
        inset: 0;
        pointer-events: none;
        z-index: 10;
        display: flex;
        align-items: flex-end;
        justify-content: flex-start;
        padding: 1.5rem 2rem;
      }
      .beat-label {
        position: absolute;
        transition: opacity 0.2s ease;
        opacity: 0;
        max-width: 20rem;
      }
      .beat-label__title {
        font-family: 'IBM Plex Mono', ui-monospace, monospace;
        font-size: 0.7rem;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: #4a9eff;
        margin: 0 0 0.25rem 0;
      }
      .beat-label__body {
        font-family: 'Poppins', sans-serif;
        font-size: 0.95rem;
        color: #bbb;
        margin: 0;
      }
      #diorama-scroll-track {
        height: 500vh;
        width: 100%;
      }
    </style>
  </head>
  <body>
    <div id="diorama-scroll-panel">
      <div id="diorama-sticky-wrap">
        <div id="diorama-container"></div>
        <div id="diorama-labels" aria-live="polite">
          {BEAT_LABELS.map((label, i) => (
            <div class="beat-label" data-beat={i} aria-hidden="true">
              <p class="beat-label__title">{label.title}</p>
              <p class="beat-label__body">{label.body}</p>
            </div>
          ))}
        </div>
      </div>
      <div id="diorama-scroll-track"></div>
    </div>
    <script src="../../../scripts/dev-diorama-scroll.ts" />
  </body>
</html>
