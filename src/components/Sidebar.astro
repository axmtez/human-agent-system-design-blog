---
import { articleSlug, type ArticleEntry } from '../lib/articles.ts';

interface Props {
  articles: ArticleEntry[];
  currentPath?: string;
}

const { articles, currentPath = '' } = Astro.props;
---

<nav class="codec-panel" aria-label="Site navigation">
  <div class="codec-panel__freq sys">FREQ ░░ 140.85</div>
  <a href="/" class="codec-panel__site sys">HAS-DESIGN</a>
  <hr class="tx-rule codec-panel__rule" />
  <div class="codec-panel__label sys">Transmissions</div>
  <ul class="codec-panel__list">
    {
      articles.map((a) => {
        const href = `/${articleSlug(a.id)}`;
        const isActive = currentPath === href;
        return (
          <li class:list={[{ 'active-marker': isActive }]}>
            <a
              class:list={['codec-panel__link', { 'codec-panel__link--active': isActive }]}
              href={href}
              aria-current={isActive ? 'page' : undefined}
            >
              {a.data.title}
            </a>
          </li>
        );
      })
    }
  </ul>
  <hr class="tx-rule codec-panel__rule" />
  <div class="codec-panel__operator sys">OPERATOR // CHAD B</div>
</nav>

<style>
  .codec-panel {
    display: flex;
    flex-direction: column;
  }

  .codec-panel__freq {
    margin-bottom: var(--space-1);
  }

  .codec-panel__site {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-text-primary);
    text-decoration: none;
  }

  .codec-panel__site:hover {
    color: var(--color-accent);
  }

  .codec-panel__rule {
    margin: var(--space-4) 0;
  }

  .codec-panel__label {
    margin-bottom: var(--space-2);
  }

  .codec-panel__list {
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .codec-panel__link {
    display: block;
    padding: var(--space-1) 0;
    font-family: var(--font-prose);
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    text-decoration: none;
  }

  .codec-panel__link:hover {
    color: var(--color-text-primary);
  }

  .codec-panel__link--active {
    color: var(--color-text-primary);
  }

  .codec-panel__operator {
    margin-top: auto;
  }
</style>
